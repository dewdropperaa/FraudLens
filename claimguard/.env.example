# Copy to .env and fill in values. Never commit .env.
# Production: set ENVIRONMENT=production — missing required vars will abort startup.

ENVIRONMENT=development

# --- Required for production (validated at startup when ENVIRONMENT=production) ---
DOCUMENT_ENCRYPTION_KEY=
# 32-byte key: 64 hex chars, or base64 of 32 bytes, or exactly 32 UTF-8 characters

CLAIMAGUARD_API_KEYS=
# Comma-separated API keys (X-API-Key header). Alternatively set CLAIMAGUARD_JWT_SECRET for Bearer JWT.

CLAIMAGUARD_JWT_SECRET=
# If set (and optional HS256 JWT), clients may use Authorization: Bearer <token> with aud=claimguard-api

CORS_ORIGINS=
# Comma-separated list, e.g. https://app.example.com,https://admin.example.com
# Never use * with credentials.

MAX_REQUEST_BODY_BYTES=262144

# --- Optional: Pinata / IPFS ---
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=

# --- Firebase / Firestore (required for claim storage when ENVIRONMENT is not test) ---
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
# Path to service account JSON, or use Application Default Credentials on GCP.
FIRESTORE_COLLECTION=claims
# Client web config (non-secret identifiers only — still avoid committing unnecessarily)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Optional: HMAC key for on-chain ZK commitment hash (overrides DOCUMENT_ENCRYPTION_KEY for that step)
# ZK_PROOF_COMMITMENT_SECRET=

# --- Optional: Ethereum (Sepolia) ---
# RPC: Alchemy dashboard → Create app → Sepolia → copy HTTPS URL, or use a public Sepolia RPC.
# ALCHEMY_URL is optional; if set, it wins over SEPOLIA_RPC_URL when both are used by helpers.
ALCHEMY_URL=
SEPOLIA_RPC_URL=
# Hex key without 0x (or with 0x). PRIVATE_KEY is an alias for SEPOLIA_PRIVATE_KEY.
SEPOLIA_PRIVATE_KEY=
PRIVATE_KEY=
CONTRACT_ADDRESS=
